# =============================================================================
# WebTrerm production environment
# Copy to .env.production and replace the placeholder values that fit your host.
# Main startup command:
#   docker compose --env-file .env.production -f docker-compose.production.yml up -d --build
# =============================================================================

# -----------------------------------------------------------------------------
# Public URLs and ports
# -----------------------------------------------------------------------------
PUBLIC_BIND_HOST=0.0.0.0
FRONTEND_PORT=8080
DJANGO_BIND_HOST=127.0.0.1
DJANGO_HOST_PORT=9000
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_HOST_PORT=5432
REDIS_BIND_HOST=127.0.0.1
REDIS_HOST_PORT=6379
MCP_BIND_HOST=127.0.0.1
STUDIO_MCP_DEMO_PORT=8765
STUDIO_KEYCLOAK_MCP_PORT=8766
TZ=Asia/Qyzylorda

SITE_URL=http://localhost:8080
FRONTEND_APP_URL=http://localhost:8080
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# -----------------------------------------------------------------------------
# Django / app mode
# -----------------------------------------------------------------------------
WEU_BUILD=prod
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key-at-least-50-characters
CHANNEL_REDIS_URL=redis://redis:6379/1
MASTER_PASSWORD=change-me-master-password

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=weu_platform
POSTGRES_USER=weu
POSTGRES_PASSWORD=change-me-postgres-password

# -----------------------------------------------------------------------------
# Security / cookies / headers
# -----------------------------------------------------------------------------
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
APP_LOG_FILE=/workspace/logs/webtrerm.log
APP_LOG_LEVEL=INFO
APP_LOG_ROTATION=50 MB
APP_LOG_RETENTION=14 days
APP_LOG_SYSLOG_ENABLED=false
APP_LOG_SYSLOG_ADDRESS=localhost:514
APP_LOG_SYSLOG_PROTOCOL=udp
APP_LOG_SYSLOG_FACILITY=LOG_USER

# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
OPENAI_API_KEY=
CODEX_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=
OLLAMA_BASE_URL=
OLLAMA_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com

# -----------------------------------------------------------------------------
# Cursor / CLI runtime
# -----------------------------------------------------------------------------
CURSOR_API_KEY=
CURSOR_CLI_HTTP_1=1
CURSOR_CLI_EXTRA_ENV=
CLI_RUNTIME_TIMEOUT_SECONDS=600
CLI_FIRST_OUTPUT_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# Email / Telegram notifications
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
PIPELINE_NOTIFY_EMAIL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Domain auth / SSO
# -----------------------------------------------------------------------------
DOMAIN_AUTH_ENABLED=false
DOMAIN_AUTH_HEADER=REMOTE_USER
DOMAIN_AUTH_HEADER_ALIASES=
DOMAIN_AUTH_AUTO_CREATE=true
DOMAIN_AUTH_LOWERCASE_USERNAMES=true
DOMAIN_AUTH_DEFAULT_PROFILE=server_only

# -----------------------------------------------------------------------------
# LDAP / AD
# -----------------------------------------------------------------------------
LDAP_ENABLED=false
LDAP_SERVER=
LDAP_PORT=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_SEARCH_BASE=
LDAP_FILTER=(objectClass=user)
LDAP_USERNAME_ATTRIBUTE=sAMAccountName
LDAP_EMAIL_ATTRIBUTE=mail
LDAP_FULL_NAME_ATTRIBUTE=cn
LDAP_START_TLS=false
LDAP_IGNORE_CERT=false
LDAP_NETWORK_TIMEOUT_SECONDS=3

# -----------------------------------------------------------------------------
# Studio MCP URLs used by backend inside the docker network
# -----------------------------------------------------------------------------
STUDIO_MCP_DEMO_URL=http://mcp-demo:8765/mcp
STUDIO_KEYCLOAK_MCP_URL=http://mcp-keycloak:8766/mcp

# -----------------------------------------------------------------------------
# Keycloak MCP defaults
# -----------------------------------------------------------------------------
KEYCLOAK_DEFAULT_PROFILE=test
KEYCLOAK_PROFILES_FILE=keycloak_profiles.json
KEYCLOAK_VERIFY_SSL=true
KEYCLOAK_ALLOW_INSECURE_HTTP=false
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_TOKEN_REALM=
KEYCLOAK_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USER=
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_EMAIL_DOMAINS=erg.kz,corp.erg.kz,mail.erg.kz
KEYCLOAK_MAX_RETRIES=3
KEYCLOAK_RETRY_DELAY=1.5
KEYCLOAK_REQUEST_TIMEOUT=30
KEYCLOAK_MAX_SEARCH_RESULTS=50
KEYCLOAK_GROUP_PAGE_SIZE=200

# -----------------------------------------------------------------------------
# Keycloak PROD profile
# -----------------------------------------------------------------------------
KEYCLOAK_PROD_URL=
KEYCLOAK_PROD_REALM=
KEYCLOAK_PROD_TOKEN_REALM=
KEYCLOAK_PROD_CLIENT_ID=admin-cli
KEYCLOAK_PROD_ADMIN_USER=
KEYCLOAK_PROD_ADMIN_PASSWORD=
KEYCLOAK_PROD_CLIENT_SECRET=
KEYCLOAK_PROD_VERIFY_SSL=true

# -----------------------------------------------------------------------------
# Keycloak TEST profile
# -----------------------------------------------------------------------------
KEYCLOAK_TEST_URL=
KEYCLOAK_TEST_REALM=
KEYCLOAK_TEST_TOKEN_REALM=
KEYCLOAK_TEST_CLIENT_ID=admin-cli
KEYCLOAK_TEST_ADMIN_USER=
KEYCLOAK_TEST_ADMIN_PASSWORD=
KEYCLOAK_TEST_CLIENT_SECRET=
KEYCLOAK_TEST_VERIFY_SSL=true

# -----------------------------------------------------------------------------
# Corporate proxies, only if needed
# -----------------------------------------------------------------------------
http_proxy=
https_proxy=
ftp_proxy=
no_proxy=localhost,127.0.0.1,::1,postgres,redis,backend,frontend,nginx,mcp-demo,mcp-keycloak
HTTP_PROXY=
HTTPS_PROXY=
FTP_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,postgres,redis,backend,frontend,nginx,mcp-demo,mcp-keycloak
